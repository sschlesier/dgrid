{
  "name": "dgrid-v2",
  "version": "1.4.1",
  "description": "Modern MongoDB GUI with AI-native development",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "tauri dev",
    "dev:frontend": "vite",
    "build": "tauri build",
    "build:frontend": "vite build",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit && tsc --noEmit -p src",
    "lint": "eslint . --ext .ts,.js,.svelte",
    "lint:fix": "eslint . --ext .ts,.js,.svelte --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "pnpm type-check && pnpm lint && pnpm test run && pnpm build:frontend && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings && cargo test --manifest-path src-tauri/Cargo.toml",
    "version": "tsx scripts/sync-version.ts",
    "release": "tsx scripts/release.ts",
    "prepare": "husky",
    "tauri": "tauri",
    "e2e": "node scripts/run-tauri-e2e.mjs",
    "e2e:headed": "node scripts/run-tauri-e2e.mjs",
    "e2e:ci": "node scripts/run-tauri-e2e.mjs --ci",
    "e2e:install-driver": "cargo install tauri-webdriver",
    "e2e:report": "node scripts/run-tauri-e2e.mjs --spec tests/webdriver/specs/smoke.e2e.mjs"
  },
  "keywords": [
    "mongodb",
    "gui",
    "tauri",
    "svelte"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.11",
    "@replit/codemirror-vim": "^6.3.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "codemirror": "^6.0.2",
    "svelte": "^5.48.1",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.7",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@wdio/cli": "^9.25.0",
    "@wdio/junit-reporter": "^9.25.0",
    "@wdio/local-runner": "^9.25.0",
    "@wdio/mocha-framework": "^9.25.0",
    "@wdio/spec-reporter": "^9.25.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "expect-webdriverio": "^5.6.5",
    "globals": "^17.1.0",
    "happy-dom": "^15.11.7",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "mongodb": "^6.21.0",
    "mongodb-memory-server": "^10.4.3",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte-check": "^4.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "webdriverio": "^9.25.0"
  }
}
